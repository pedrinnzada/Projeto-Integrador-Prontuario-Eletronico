                              <string notr="true">*{
color: black;
}
       QGroupBox {
        font-size: 15px;
        font-weight: bold;
        border: 2px solid rgb(85, 140, 127);
        border-radius: 10px;
       }
       QGroupBox::title {
        subcontrol-origin: margin;
        left: 12px;
        padding: 0 6px;
        color: rgb(85, 170, 127);
       }
       QLabel {
        font-size: 14px;
       }
       QLineEdit {
        font-size: 14px;
        padding: 6px;
        border-radius: 6px;
        border: 1px solid #B0BEC5;
       }
       QLineEdit:focus {
        border: 2px solid rgb(85, 170, 127);;
       }
		QRadioButton::indicator {
    width: 5px;
    height:5px;
}
 
QRadioButton::indicator::hover {
	
	background-color: rgb(255, 255, 255);
}
 
QRadioButton::indicator:checked {
 
	background-color: rgb(85, 170, 127);
    border: 2px solid #418462;
}

QRadioButton{
font-size: 13px;
}</string>
