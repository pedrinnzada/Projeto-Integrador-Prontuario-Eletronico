                            <string notr="true">
QTableWidget {
    background-color: #ffffff;
    border: none;
    border-radius: 12px;
    gridline-color: #e0e0e0;
    font-size: 14px;
    padding: 5px;
}

/* Cabeçalho */
QHeaderView::section {
    background-color: rgb(85, 170, 127);
    color: white;
    font-weight: bold;
    font-size: 14px;
    border: none;
    padding: 8px;
}

/* Linhas */
QTableWidget::item {
    padding: 8px;
}

/* Alternância de linhas */
QTableWidget::item:nth-child(even) {
    background-color: #f6f9f8;
}

/* Hover */
QTableWidget::item:hover {
    background-color: rgba(85, 170, 127, 40);
}

/* Seleção */
QTableWidget::item:selected {
    background-color: rgb(85, 170, 127);
    color: white;
}

/* Barra de rolagem */
QScrollBar:vertical {
    border: none;
    background: #f0f0f0;
    width: 8px;
    margin: 0px;
    border-radius: 4px;
}

QScrollBar::handle:vertical {
    background: rgb(85, 170, 127);
    min-height: 25px;
    border-radius: 4px;
}

QScrollBar::handle:vertical:hover {
    background: rgb(70, 150, 110);
}</string>
