                            <widget class="QTabWidget" name="tabWidget_2">
                             <property name="styleSheet">
                              <string notr="true">/* ===== TAB WIDGET GERAL ===== */
QTabWidget::pane {
    border: 1px solid rgb(60, 130, 95);
    border-radius: 10px;
    padding: 6px;
}

/* ===== BARRA DAS ABAS ===== */
QTabBar::tab {
    background-color: rgb(85, 170, 127);
    color: white;
    padding: 10px 18px;
    margin-right: 6px;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    font-size: 13px;
    font-weight: 500;
    min-width: 120px;
}

/* ===== ABA SELECIONADA ===== */
QTabBar::tab:selected {
     /* verde ativo */
	background-color: rgb(39, 104, 78);
    color: white;
    font-weight: 600;
}

/* ===== HOVER (verde escuro elegante) ===== */
QTabBar::tab:hover {
    background-color: rgb(45, 120, 90);
}

/* ===== ABA NÃO SELECIONADA ===== */
QTabBar::tab:!selected {
    margin-top: 4px;
    opacity: 0.95;
}</string>
