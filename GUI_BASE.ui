       }
       QGroupBox::title {
        subcontrol-origin: margin;
        left: 12px;
        padding: 0 6px;
        color: rgb(85, 170, 127);
       }
       QLabel {
        font-size: 14px;
       }
       QLineEdit {
        font-size: 14px;
        padding: 6px;
        border-radius: 6px;
        border: 1px solid #B0BEC5;
